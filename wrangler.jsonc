{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "minte-ai-academy-demo",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-07-16",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "ai": {
    "binding": "AI",
    "remote": true
  }
}
